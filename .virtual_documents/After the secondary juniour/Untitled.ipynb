


# bad decision data and their reasons in the form of the pie chart 


import pandas as pd 


import numpy as np 


import matplotlib.pyplot as plt


data = pd.read_csv('bad_stream_selection_result.csv')


df = pd.DataFrame(data)


df


df.head()





import matplotlib.pyplot as plt
lables = df['Stream / Education Choice']
distribution = df['Regret Rate within 3 Years']
plt.style.use('ggplot')
plt.pie(distribution ,
       labels = lables,
       shadow = True,
       autopct = '%1.1f%%',wedgeprops = {'edgecolor':'black','linewidht':2,'linestyle':'--'})
plt.title('Regret Rate After 3 year with certain stream')
plt.show()



 



