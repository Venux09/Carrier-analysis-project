#Plotting the bar 
import pandas as pd 
df = pd.read_csv('data3.csv')
df_pcb = df.loc[0:11].copy()#creating different dataframes for both pcm and pcB
df_pcm  = df.loc[12:29].copy()
carrier = df_pcb['Career_Path']
current_salaries = df_pcb['Current_Avg_Salary_INR']
plt.bar(carrier,current_salaries/100000,color= 'blue')
plt.xlabel('Carrier names')
plt.ylabel('Salaries[LPA]')
plt.title('The salaries of the job of the pcb with Career names')
plt.xticks(rotation = 45,fontsize = 7)
plt.legend()
plt.tight_layout()
plt.style.use('dark_background')



